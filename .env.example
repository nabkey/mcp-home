# Cloudflare Tunnel (required)
# Create an API token at https://dash.cloudflare.com/profile/api-tokens
# with Tunnel:Edit, DNS:Edit, and Access: Organizations/Apps (Read) permissions.
CF_API_TOKEN=your-cloudflare-api-token
CF_ACCOUNT_ID=your-cloudflare-account-id
CF_ZONE_ID=your-dns-zone-id
CF_HOSTNAME=mcp.yourdomain.com
# CF_TUNNEL_NAME=mcp-server
#
# Authentication: the server auto-discovers the Cloudflare Access team domain
# and application AUD at startup using the API token above. You need a
# self_hosted Access application on CF_HOSTNAME with:
#   - An identity policy (e.g. email allowlist)
#   - OAuth configuration enabled with dynamic client registration
# Create one in Zero Trust dashboard > Access > Applications > Self-hosted.
# Pass --insecure to skip auth (DANGEROUS: exposes server without auth).

# Home Assistant (optional — both required if either is set)
# HASS_URL=http://homeassistant.local:8123
# HASS_TOKEN=your-long-lived-access-token

# Sonarr (optional — both required if either is set)
# SONARR_URL=http://localhost:8989
# SONARR_API_KEY=your-sonarr-api-key

# Radarr (optional — both required if either is set)
# RADARR_URL=http://localhost:7878
# RADARR_API_KEY=your-radarr-api-key

# Frigate NVR (optional)
# FRIGATE_URL=http://localhost:5000
